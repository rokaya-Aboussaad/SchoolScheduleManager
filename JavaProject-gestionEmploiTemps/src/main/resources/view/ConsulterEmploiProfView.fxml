<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.essprjtjava.controller.ConsulterEmploiProfController"
            prefHeight="750.0" prefWidth="1100.0"
            style="-fx-background-color: #f5f5f5;">

    <!-- En-tête -->
    <top>
        <VBox style="-fx-background-color: #9b59b6; -fx-padding: 20;">
            <Label text="👨‍🏫 Emploi du Temps par Professeur" textFill="white">
                <font>
                    <Font name="System Bold" size="24.0"/>
                </font>
            </Label>
            <Label text="Consultez l'emploi du temps hebdomadaire de chaque professeur" textFill="#ecf0f1">
                <font>
                    <Font size="13.0"/>
                </font>
                <VBox.margin>
                    <Insets top="5.0"/>
                </VBox.margin>
            </Label>
        </VBox>
    </top>

    <!-- Contenu -->
    <center>
        <VBox spacing="20.0" style="-fx-padding: 30;">

            <!-- Sélection du professeur -->
            <HBox spacing="15.0" alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
                <Label text="Sélectionner un professeur :" style="-fx-font-weight: bold; -fx-font-size: 16; -fx-text-fill: #2c3e50;"/>
                <ComboBox fx:id="cbProfesseur" promptText="Choisir un professeur"
                          prefWidth="350.0" style="-fx-font-size: 14;"
                          onAction="#handleProfesseurSelection"/>

                <Region HBox.hgrow="ALWAYS"/>

                <Button text="🖨️ Imprimer"
                        onAction="#handleImprimer"
                        style="-fx-background-color: #9b59b6; -fx-text-fill: white; -fx-font-size: 13; -fx-background-radius: 5; -fx-cursor: hand; -fx-padding: 10 20;"/>
            </HBox>

            <!-- Tableau emploi du temps -->
            <ScrollPane fitToWidth="true" fitToHeight="true" style="-fx-background-color: transparent;">
                <VBox fx:id="vboxEmploi" spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">

                    <!-- Message initial -->
                    <VBox fx:id="vboxMessage" alignment="CENTER" spacing="15.0" style="-fx-padding: 50;">
                        <Label text="👨‍🏫" style="-fx-font-size: 48;"/>
                        <Label text="Sélectionnez un professeur pour afficher son emploi du temps"
                               style="-fx-font-size: 16; -fx-text-fill: #7f8c8d; -fx-font-style: italic;"/>
                    </VBox>

                    <!-- Grille emploi du temps -->
                    <GridPane fx:id="gridEmploi" hgap="2.0" vgap="2.0" visible="false">
                    </GridPane>

                </VBox>
            </ScrollPane>

        </VBox>
    </center>

    <!-- Pied de page -->
    <bottom>
        <HBox spacing="15.0" alignment="CENTER" style="-fx-background-color: white; -fx-padding: 15; -fx-border-color: #e0e0e0; -fx-border-width: 1 0 0 0;">
            <Label fx:id="lblInfo" text="" style="-fx-font-size: 13; -fx-text-fill: #7f8c8d;"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="Fermer"
                    onAction="#handleFermer"
                    prefWidth="120.0" prefHeight="40.0"
                    style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-font-size: 13; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;">
            </Button>
        </HBox>
    </bottom>

</BorderPane>