<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.essprjtjava.controller.CreerSeanceController"
            prefHeight="800.0" prefWidth="1200.0"
            style="-fx-background-color: #f5f5f5;">

    <!-- En-tête -->
    <top>
        <VBox style="-fx-background-color: #27ae60; -fx-padding: 20;">
            <Label text="Gestion des Emplois du Temps" textFill="white">
                <font>
                    <Font name="System Bold" size="24.0"/>
                </font>
            </Label>
            <Label text="Créez et visualisez les emplois du temps de tous les groupes" textFill="#ecf0f1">
                <font>
                    <Font size="13.0"/>
                </font>
                <VBox.margin>
                    <Insets top="5.0"/>
                </VBox.margin>
            </Label>
        </VBox>
    </top>

    <!-- Contenu -->
    <center>
        <SplitPane dividerPositions="0.45" orientation="VERTICAL">

            <!-- Partie Haute : Formulaire de création -->
            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
                <VBox spacing="20.0" style="-fx-padding: 30;">

                    <!-- Sélection du groupe -->
                    <VBox spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
                        <Label text="1. Sélectionner le Groupe" style="-fx-font-weight: bold; -fx-font-size: 18; -fx-text-fill: #2c3e50;"/>
                        <HBox spacing="15.0" alignment="CENTER_LEFT">
                            <VBox spacing="8.0">
                                <Label text="Groupe *" style="-fx-font-weight: bold; -fx-font-size: 14;"/>
                                <ComboBox fx:id="cbGroupe" promptText="Sélectionnez un groupe"
                                          prefWidth="300.0" style="-fx-font-size: 13;"
                                          onAction="#handleGroupeSelection"/>
                            </VBox>
                        </HBox>
                    </VBox>

                    <!-- Grille d'emploi du temps -->
                    <VBox fx:id="vboxEmploi" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
                        <Label text="2. Planifier les Séances" style="-fx-font-weight: bold; -fx-font-size: 18; -fx-text-fill: #2c3e50;"/>

                        <ScrollPane fitToWidth="true" prefHeight="250.0" style="-fx-background-color: transparent;">
                            <GridPane fx:id="gridEmploi" hgap="10.0" vgap="10.0" style="-fx-padding: 10;">
                            </GridPane>
                        </ScrollPane>

                        <HBox spacing="15.0" alignment="CENTER_LEFT">
                            <Button text="+ Ajouter une Séance"
                                    onAction="#handleAjouterSeance"
                                    style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size: 13; -fx-background-radius: 5; -fx-cursor: hand; -fx-padding: 10 20;"/>

                            <Button fx:id="btnEnregistrer" text="💾 Enregistrer l'Emploi du Temps"
                                    onAction="#handleEnregistrer"
                                    style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-size: 13; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand; -fx-padding: 10 20;"/>
                        </HBox>
                    </VBox>

                    <!-- Message -->
                    <Label fx:id="lblMessage" textFill="#e74c3c" wrapText="true"
                           style="-fx-font-size: 14; -fx-font-weight: bold; -fx-padding: 10;"/>

                </VBox>
            </ScrollPane>

            <!-- Partie Basse : Affichage des emplois du temps -->
            <ScrollPane fitToWidth="true" style="-fx-background-color: #ecf0f1;">
                <VBox fx:id="vboxEmploisGroupes" spacing="20.0" style="-fx-padding: 30;">
                    <Label text="📅 Emplois du Temps des Groupes"
                           style="-fx-font-weight: bold; -fx-font-size: 20; -fx-text-fill: #2c3e50;"/>

                    <!-- Les emplois du temps seront ajoutés ici dynamiquement -->
                </VBox>
            </ScrollPane>

        </SplitPane>
    </center>

    <!-- Pied de page -->
    <bottom>
        <HBox spacing="15.0" alignment="CENTER" style="-fx-background-color: white; -fx-padding: 15; -fx-border-color: #e0e0e0; -fx-border-width: 1 0 0 0;">
            <Button text="🔄 Actualiser les Emplois"
                    onAction="#handleActualiser"
                    prefWidth="200.0" prefHeight="40.0"
                    style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size: 13; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;">
            </Button>

            <Button fx:id="btnAnnuler" text="Fermer"
                    onAction="#handleAnnuler"
                    prefWidth="150.0" prefHeight="40.0"
                    style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-font-size: 13; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;">
            </Button>
        </HBox>
    </bottom>

</BorderPane>