<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.essprjtjava.controller.ModifierSeanceController"
            prefHeight="800.0" prefWidth="1200.0"
            style="-fx-background-color: #f5f5f5;">

    <top>
        <VBox style="-fx-background-color: #f39c12; -fx-padding: 20;">
            <Label text="✏️ Modifier / Supprimer des Séances" textFill="white">
                <font><Font name="System Bold" size="24.0"/></font>
            </Label>
            <Label text="Visualisez et gérez les emplois du temps" textFill="#ecf0f1">
                <font><Font size="13.0"/></font>
                <VBox.margin><Insets top="5.0"/></VBox.margin>
            </Label>
        </VBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.4" orientation="VERTICAL">

            <!-- Partie Haute : Sélection et Modification -->
            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
                <VBox spacing="20.0" style="-fx-padding: 30;">

                    <!-- Sélection groupe -->
                    <VBox spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
                        <Label text="1. Sélectionner un Groupe" style="-fx-font-weight: bold; -fx-font-size: 18; -fx-text-fill: #2c3e50;"/>
                        <HBox spacing="15.0" alignment="CENTER_LEFT">
                            <VBox spacing="8.0">
                                <Label text="Groupe *" style="-fx-font-weight: bold; -fx-font-size: 14;"/>
                                <ComboBox fx:id="cbGroupe" promptText="Sélectionnez un groupe"
                                          prefWidth="300.0" style="-fx-font-size: 13;"
                                          onAction="#handleGroupeSelection"/>
                            </VBox>
                        </HBox>
                    </VBox>

                    <!-- Formulaire de modification -->
                    <VBox fx:id="vboxModif" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);" visible="false" managed="false">
                        <Label text="2. Modifier la Séance Sélectionnée" style="-fx-font-weight: bold; -fx-font-size: 18; -fx-text-fill: #2c3e50;"/>

                        <GridPane hgap="15.0" vgap="15.0">
                            <VBox spacing="8.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                <Label text="Jour *" style="-fx-font-weight: bold; -fx-font-size: 13;"/>
                                <ComboBox fx:id="cbJour" prefWidth="150.0" style="-fx-font-size: 13;"/>
                            </VBox>

                            <VBox spacing="8.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                <Label text="Heure Début *" style="-fx-font-weight: bold; -fx-font-size: 13;"/>
                                <ComboBox fx:id="cbHeureDebut" prefWidth="120.0" style="-fx-font-size: 13;"/>
                            </VBox>

                            <VBox spacing="8.0" GridPane.columnIndex="2" GridPane.rowIndex="0">
                                <Label text="Heure Fin *" style="-fx-font-weight: bold; -fx-font-size: 13;"/>
                                <ComboBox fx:id="cbHeureFin" prefWidth="120.0" style="-fx-font-size: 13;"/>
                            </VBox>

                            <VBox spacing="8.0" GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="1">
                                <Label text="Professeur / Matière *" style="-fx-font-weight: bold; -fx-font-size: 13;"/>
                                <ComboBox fx:id="cbProfesseur" prefWidth="280.0" style="-fx-font-size: 13;"/>
                            </VBox>

                            <VBox spacing="8.0" GridPane.columnIndex="2" GridPane.rowIndex="1">
                                <Label text="Salle *" style="-fx-font-weight: bold; -fx-font-size: 13;"/>
                                <ComboBox fx:id="cbSalle" prefWidth="120.0" style="-fx-font-size: 13;"/>
                            </VBox>
                        </GridPane>

                        <HBox spacing="15.0" alignment="CENTER_LEFT">
                            <Button text="💾 Enregistrer" onAction="#handleEnregistrerModif"
                                    style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-size: 13; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand; -fx-padding: 10 20;"/>

                            <Button text="🗑️ Supprimer cette séance" onAction="#handleSupprimerSeance"
                                    style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-size: 13; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand; -fx-padding: 10 20;"/>

                            <Button text="❌ Annuler" onAction="#handleAnnuler"
                                    style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-font-size: 13; -fx-background-radius: 5; -fx-cursor: hand; -fx-padding: 10 20;"/>
                        </HBox>

                        <Label fx:id="lblMessage" textFill="#e74c3c" wrapText="true" style="-fx-font-size: 13; -fx-font-weight: bold;"/>
                    </VBox>

                </VBox>
            </ScrollPane>

            <!-- Partie Basse : Affichage emploi du temps -->
            <ScrollPane fitToWidth="true" style="-fx-background-color: #ecf0f1;">
                <VBox fx:id="vboxEmploisGroupes" spacing="20.0" style="-fx-padding: 30;">
                    <Label text="📅 Emplois du Temps - Cliquez sur une séance pour la modifier"
                           style="-fx-font-weight: bold; -fx-font-size: 20; -fx-text-fill: #2c3e50;"/>
                </VBox>
            </ScrollPane>

        </SplitPane>
    </center>

    <bottom>
        <HBox spacing="15.0" alignment="CENTER" style="-fx-background-color: white; -fx-padding: 15; -fx-border-color: #e0e0e0; -fx-border-width: 1 0 0 0;">
            <Button text="🔄 Actualiser" onAction="#handleActualiser"
                    prefWidth="150.0" prefHeight="40.0"
                    style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size: 13; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="Fermer" onAction="#handleFermer"
                    prefWidth="120.0" prefHeight="40.0"
                    style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-font-size: 13; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;"/>
        </HBox>
    </bottom>

</BorderPane>