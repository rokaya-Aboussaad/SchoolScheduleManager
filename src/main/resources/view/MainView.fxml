<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.essprjtjava.controller.MainController"
            prefHeight="600.0" prefWidth="900.0"
            style="-fx-background-color: #f5f5f5;">

    <!-- En-tête -->
    <top>
        <VBox style="-fx-background-color: #2c3e50; -fx-padding: 20;">
            <Label text="Gestion des Emplois du Temps" textFill="white">
                <font>
                    <Font name="System Bold" size="28.0"/>
                </font>
            </Label>
            <Label text="Système de gestion pour étudiants et professeurs" textFill="#ecf0f1">
                <font>
                    <Font size="14.0"/>
                </font>
                <VBox.margin>
                    <Insets top="5.0"/>
                </VBox.margin>
            </Label>
        </VBox>
    </top>

    <!-- Contenu central -->
    <center>
        <VBox spacing="30.0" alignment="CENTER" style="-fx-padding: 40;">

            <!-- Section Gestion des Séances -->
            <VBox spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
                <Label text="Gestion des Séances" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

                <HBox spacing="15.0" alignment="CENTER">
                    <Button fx:id="btnCreerSeance" text="Créer un Emploi du Temps"
                            onAction="#handleCreerSeance"
                            prefWidth="250.0" prefHeight="50.0"
                            style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;">
                    </Button>

                    <Button fx:id="btnModifierSeance" text="Modifier / Supprimer"
                            onAction="#handleModifierSeance"
                            prefWidth="250.0" prefHeight="50.0"
                            style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;">
                    </Button>
                </HBox>
            </VBox>

            <!-- Section Consultation -->
            <VBox spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
                <Label text="Consultation des Emplois du Temps" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

                <HBox spacing="15.0" alignment="CENTER">
                    <Button fx:id="btnConsulterGroupe" text="Emploi du Temps - Groupe"
                            onAction="#handleConsulterGroupe"
                            prefWidth="250.0" prefHeight="50.0"
                            style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;">
                    </Button>

                    <Button fx:id="btnConsulterProf" text="Emploi du Temps - Professeur"
                            onAction="#handleConsulterProf"
                            prefWidth="250.0" prefHeight="50.0"
                            style="-fx-background-color: #9b59b6; -fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;">
                    </Button>
                </HBox>
            </VBox>

        </VBox>
    </center>

    <!-- Pied de page -->
    <bottom>
        <HBox alignment="CENTER" style="-fx-background-color: #34495e; -fx-padding: 15;">
            <Label text="© 2026 - Système de Gestion d'Emplois du Temps" textFill="#ecf0f1">
                <font>
                    <Font size="12.0"/>
                </font>
            </Label>
        </HBox>
    </bottom>

</BorderPane>